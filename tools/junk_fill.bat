@echo off
setlocal EnableExtensions DisableDelayedExpansion
set "NO_PAUSE="
if /I "%~1"=="--no-pause" set "NO_PAUSE=1"

echo =========================================
echo Junk Text File Generator
echo =========================================

echo Enter the output text file path.
set /p "OUTPUT=Path (default: %~dp0junk.txt): "
if not defined OUTPUT set "OUTPUT=%~dp0junk.txt"

echo Enter target size. MB is the default unit.
echo Examples: 5   1.5gb   800kb
set /p "SIZE=Size (default: 5): "
if not defined SIZE set "SIZE=5"

set "OUTPUT_PATH=%OUTPUT%"
set "TARGET_SIZE=%SIZE%"
set "PS_"

powershell -NoProfile -ExecutionPolicy Bypass -EncodedCommand %PS_ENCODED%
if errorlevel 1 (
  echo Failed to generate the file.
  if not defined NO_PAUSE pause
  exit /b 1
)

echo Done.
if not defined NO_PAUSE pause
